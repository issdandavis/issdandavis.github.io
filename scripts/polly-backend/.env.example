# Polly Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# ── Network ──────────────────────────────────────────────────────────────────
# Host to bind on. 0.0.0.0 = all interfaces (required when behind ProtonVPN).
POLLY_HOST=0.0.0.0

# Port Polly listens on.
# When using ProtonVPN port forwarding, set this to the port ProtonVPN assigns.
# Find it in the ProtonVPN Windows app → Port Forwarding shortcut (hover to see the number).
POLLY_PORT=8001

# ── Ollama (server-side LLM) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
POLLY_MODEL=llama3.2:3b

# ── Sacred Egg flywheel ───────────────────────────────────────────────────────
# Change this! Used to derive sealing keys for every egg.
# Generate a strong value: python -c "import secrets; print(secrets.token_hex(32))"
POLLY_EGG_KEY_SEED=change-me-generate-with-secrets-token-hex-32

# Number of interactions to bundle into one protein file for training ingestion.
POLLY_CLUTCH_SIZE=12

# Where to write eggs. Defaults to scripts/polly-backend/eggs/ if unset.
# POLLY_EGG_DIR=/path/to/eggs

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Defaults to * if unset.
# POLLY_CORS_ORIGINS=https://aethermoore.com,https://www.aethermoore.com
